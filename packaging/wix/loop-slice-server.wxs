<?xml version="1.0" encoding="UTF-8"?>
<!--
  Server-only MSI: unsigned, per-user. Installs the headless dedicated server and
  run-server.ps1 (binds all interfaces; clients connect to this machine's address).
  Built with: wix build packaging/wix/loop-slice-server.wxs -d BinDir=<staged> -d Version=0.1.N.0
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="V-Sekai Loop-Slice Server"
           Manufacturer="V-Sekai"
           Version="$(Version)"
           UpgradeCode="5e8c2f3b-2d4a-4b6c-9f7e-0a1b2c3d4e5f"
           Scope="perUser"
           Compressed="yes">
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="V-Sekai Loop-Slice Server">
        <Component Id="C_Server">
          <File Source="$(BinDir)/loop-slice-server.exe" />
        </Component>
        <Component Id="C_RunServer">
          <File Id="runServerPs1" Source="$(BinDir)/run-server.ps1" />
        </Component>
        <Component Id="C_RunServerCmd">
          <File Id="runServerCmd" Source="$(BinDir)/run-server.cmd" />
        </Component>
        <Component Id="C_Obs">
          <File Source="$(BinDir)/setup-observability.ps1" />
        </Component>
        <Component Id="C_Readme">
          <File Source="$(BinDir)/README.md" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="C_Shortcut">
        <Shortcut Id="RunServerShortcut"
                  Name="V-Sekai Loop-Slice Server"
                  Description="Run the authoritative loot-action server"
                  Target="[#runServerCmd]"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="CleanupShortcut" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\V-Sekai\LoopSliceServer" Name="installed"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <Feature Id="Main" Title="V-Sekai Loop-Slice Server" Level="1">
      <ComponentRef Id="C_Server" />
      <ComponentRef Id="C_RunServer" />
      <ComponentRef Id="C_RunServerCmd" />
      <ComponentRef Id="C_Obs" />
      <ComponentRef Id="C_Readme" />
      <ComponentRef Id="C_Shortcut" />
    </Feature>
  </Package>
</Wix>
